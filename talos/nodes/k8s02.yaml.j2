---
machine:
  network:
    hostname: k8s02
    interfaces:
      - interface: bond0
        dhcp: true
        bond:
          mode: 802.3ad
          lacpRate: fast
          xmitHashPolicy: layer2
          miimon: 100
          updelay: 200
          downdelay: 200
          interfaces:
            - enp1s0f0
            - enp1s0f1
          mtu: 1500
  nodeLabels:
    topology.kubernetes.io/zone: m
  type: controlplane
